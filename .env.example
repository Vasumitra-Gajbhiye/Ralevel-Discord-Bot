# Repo-root env file used by apps/bot (via loadEnv) and apps/web (via next.config).
# Copy to .env — see docs/environment-variables.md
#
# Shared (bot + web):
#   MONGO_URI, GUILD_ID
# Web-only (Clerk auth — apps/web):
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY, CLERK_SECRET_KEY
#   NEXT_PUBLIC_CLERK_SIGN_IN_URL, NEXT_PUBLIC_CLERK_SIGN_UP_URL
#   NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL, NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL
# Bot-only secrets:
#   TOKEN, REDIS_URL, CLIENT_ID
#
# Channel/role IDs below are SEED FALLBACKS only. After first boot (or
# `pnpm --filter @ralevel/bot seed:guild-config`), live config lives in the
# MongoDB GuildConfig document and is edited via the web dashboard.
# Restart the bot after dashboard settings changes.

TOKEN=your_discord_bot_token_here
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/r_alevel_bot

# Web dashboard auth (Clerk) — see docs/environment-variables.md
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
REDIS_URL=redis://127.0.0.1:6379
GUILD_ID=your_discord_server_id
CLIENT_ID=your_discord_application_id
APPLICATION_CHANNEL=channel_id
REVIEW_CHANNEL=channel_id
CERT_UPDATES_CHANNEL=channel_id
GRAPHIC_CHANNEL=channel_id
DEV_CHANNEL=channel_id
WRITER_CHANNEL=channel_id
WELCOME_CHANNEL=channel_id
MOD_ACTION_CHANNEL=channel_id
VENT_CHANNEL=channel_id
MOD_LOG_CHANNEL_ID=channel_id
LEVELUP_CHANNEL_ID=channel_id
QOTD_REMINDER_CHANNEL_ID=channel_id
ADMIN_ROLE_ID=role_id
GFX_HEAD_ROLE_ID=role_id
DC_HEAD_ROLE_ID=role_id
RDT_HEAD_ROLE_ID=role_id
HLP_HEAD_ROLE_ID=role_id
COMM_HEAD_ROLE_ID=role_id
GENERAL_STAFF_ROLE_ID=role_id
SR_MOD_ROLE_ID=role_id
JR_MOD_ROLE_ID=role_id
TRIAL_MOD_ROLE_ID=role_id
REDDIT_MOD_ROLE_ID=role_id
SR_HELPER_ROLE_ID=role_id
JR_HELPER_ROLE_ID=role_id
LEAD_DESIGNER_ROLE_ID=role_id
DESIGNER_ROLE_ID=role_id
TRIAL_DESIGNER_ROLE_ID=role_id
RESOURCE_CONTRIBUTOR_ROLE_ID=role_id
ENGAGEMENT_COORDINATOR_ROLE_ID=role_id
ENGAGEMENT_SPECIALIST_ROLE_ID=role_id
ENGAGEMENT_TRIAL_ROLE_ID=role_id
IAL_AGENT_ROLE_ID=role_id
INTERNAL_AFFAIR_AND_LOGISTICS_ROLE_ID=role_id
WRITER_ROLE_ID=role_id
BOOSTER_ROLE_ID=role_id
ROLE_BEGINNER_ROLE_ID=role_id
BEGINNER_ROLE_ID=role_id
INTERMEDIATE_ROLE_ID=role_id
ADVANCED_ROLE_ID=role_id
EXPERT_ROLE_ID=role_id
GIGACHAD_ROLE_ID=role_id
DISABLED_CHANNELS=["channel_id"]
DISABLED_CATEGORIES=["category_id"]
# Deprecated: merged into DISABLED_CHANNELS on new guild configs
STAFF_CHANNEL_IDS=channel_id_1,channel_id_2
MOD_ROLES=role_id_1,role_id_2
