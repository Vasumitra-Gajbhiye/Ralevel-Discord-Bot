{
  "name": "ralevel",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "dev:bot": "turbo run dev --filter=@ralevel/bot",
    "dev:web": "turbo run dev --filter=@ralevel/web",
    "start:bot": "turbo run start --filter=@ralevel/bot",
    "build:web": "turbo run build --filter=@ralevel/web"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
